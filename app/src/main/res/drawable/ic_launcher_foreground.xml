<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- (a) 글라스 디스크 바디 — 반투명 흰색 반구 (radial alpha fade) -->
    <path android:pathData="M54,54 m-26,0 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="26"
                android:type="radial">
                <item android:color="#52FFFFFF" android:offset="0.0" />
                <item android:color="#14FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- (b) 상단 볼록 하이라이트 — 위에서 내려오는 빛 반사 타원 -->
    <path android:pathData="M48,38 m-18,0 a18,8 0 1,0 36,0 a18,8 0 1,0 -36,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="48"
                android:endY="46"
                android:startX="48"
                android:startY="30"
                android:type="linear">
                <item android:color="#8CFFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- (c) 상단 rim light — 글라스 윗 테두리 빛 반사 -->
    <path
        android:pathData="M30,48 A24,24 0 0 1 78,48"
        android:strokeColor="#8CFFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="1.2" />

    <!-- (d) 하단 내부 그림자 — 볼록감 강화 -->
    <path
        android:pathData="M32,58 A22,22 0 0 0 76,58"
        android:strokeColor="#1F000000"
        android:strokeLineCap="round"
        android:strokeWidth="1.2" />

    <!-- (e) 게이지 호 — 글라스 안쪽 흰색 각인 -->
    <path
        android:pathData="M37,63 A17,17 0 1 1 71,63"
        android:strokeColor="#EBFFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="2.6" />

    <!-- (f) 뾰족한 바늘 — 끝으로 갈수록 뾰족해지는 삼각형 -->
    <path
        android:fillColor="#FAFFFFFF"
        android:pathData="M65.1,43.9 L55.2,55.3 L52.8,52.7 Z" />

    <!-- (g) 허브 외곽 — 흰 디스크 -->
    <path
        android:fillColor="#FAFFFFFF"
        android:pathData="M54,54 m-3.2,0 a3.2,3.2 0 1,0 6.4,0 a3.2,3.2 0 1,0 -6.4,0" />

    <!-- (h) 허브 중심점 — 베이스와 동일한 다크레드 핀 -->
    <path
        android:fillColor="#A50021"
        android:pathData="M54,54 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0" />
</vector>
